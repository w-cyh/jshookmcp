{
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "off",
    "nursery": "off"
  },
  "rules": {
    "no-unused-vars": "error",
    "no-underscore-dangle": [
      "error",
      {
        "allow": [
          "__aiHookMetadata",
          "__aiHooks",
          "__bridgeResults",
          "__capturedAPIs",
          "__cdpTimingOffset",
          "__domObserver",
          "__error__",
          "__fetchInterceptorInjected",
          "__fetchRequests",
          "__functionTracer",
          "__getFetchRequests",
          "__getXHRRequests",
          "__jshookElectronCompatPatched",
          "__jshookSSEMonitor",
          "__more",
          "__networkRequests",
          "__order",
          "__pwOriginalFetch",
          "__pwOriginalXMLHttpRequest",
          "__scratchpad",
          "__scriptReplacePersistRules",
          "__truncated__",
          "__truncatedKeys",
          "__turnstile_callbacks",
          "__type",
          "__wasmInstances",
          "__wasmModuleStorage",
          "__webgpuDeviceCache",
          "__workerUrls",
          "__xhrInterceptorInjected",
          "__xhrRequests",
          "_bodyUnavailable",
          "_executionMetrics",
          "_id",
          "_meta",
          "_nextStepHint",
          "_note",
          "_offload",
          "_raw_summary",
          "_requestId",
          "_source",
          "_tabContext",
          "_contextType",
          "_DuplicateHandle",
          "_Gcp",
          "_k32",
          "_libc",
          "_NtAllocateVirtualMemory",
          "_NtClose",
          "_NtCreateThreadEx",
          "_NtFreeVirtualMemory",
          "_NtOpenProcess",
          "_NtProtectVirtualMemory",
          "_NtQueryObject",
          "_NtQuerySystemInformation",
          "_NtReadVirtualMemory",
          "_NtResumeProcess",
          "_NtSuspendProcess",
          "_NtWriteVirtualMemory",
          "_ntdll",
          "_pages",
          "_ptraceFn",
          "_resolved",
          "_version",
          "_vid",
          "_va",
          "_Va",
          "_vdsoGadgetCache",
          "_Vf",
          "_Vp",
          "_waitpidFn",
          "_Wpm"
        ]
      }
    ],
    "prefer-const": "error",
    "eqeqeq": "error",
    "no-constant-condition": "error",
    "unicorn/require-post-message-target-origin": "off"
  },
  "plugins": ["unicorn", "import", "typescript"],
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "overrides": [
    {
      "files": ["tests/**/*.ts"],
      "rules": {
        "unicorn/consistent-function-scoping": "off"
      }
    }
  ]
}
